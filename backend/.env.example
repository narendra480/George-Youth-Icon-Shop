# Database Configuration (Neon PostgreSQL)
DATABASE_URL=postgresql+psycopg2://postgres:password@hostname:5432/gyis

# Security
SECRET_KEY=replace-with-secure-secret-key
JWT_SECRET=replace-with-jwt-secret
JWT_REFRESH_SECRET=replace-with-jwt-refresh-secret

# Environment
ENVIRONMENT=production
DEBUG=False

# CORS Configuration (Vercel)
CORS_ORIGINS=["https://georgesyouthicon.vercel.app","http://localhost:5173"]

# Frontend/Backend URLs
FRONTEND_URL=https://georgesyouthicon.vercel.app
BACKEND_URL=https://georgesyouthicon.up.railway.app

# Cloudinary Configuration
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Token Configuration
ACCESS_TOKEN_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRES_HOURS=1

# Email Configuration
EMAIL_BACKEND=smtp
EMAIL_FROM=noreply@georgesyouthicon.com